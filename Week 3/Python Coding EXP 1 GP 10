import serial
import time

ser = serial.Serial('COM5', 9600)
time.sleep(2)

print("Running... Press CTRL+C to stop")

try:
    while True:
        adc_raw = ser.readline().decode().strip()

        if adc_raw.isdigit():
            adc = int(adc_raw)
            print("ADC Value:", adc)

            # Logic LED
            if adc > 512:
                ser.write(b"LED ON\n")
                print("LED ON")
            else:
                ser.write(b"LED OFF\n")
                print("LED OFF")

except KeyboardInterrupt:
    print("Stopped by user")

finally:
    ser.close()
    print("Serial closed")
